# MiroFishTrader 환경설정 예시 — 복사해서 `.env` 로 사용 (.env 는 gitignore됨)
# 값이 비어 있으면 해당 소스는 자동 skip (graceful degrade).

# ── LLM (로컬 Ollama, OpenAI 호환) ──
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL_NAME=qwen2.5:7b

# ── MiroFish 백엔드 / 공유 폴더 ──
MIROFISH_SHARED_DIR=./shared/mirofish
MIROFISH_API_URL=http://localhost:5001

# ── Slack (Incoming Webhook) ──
SLACK_WEBHOOK_URL=

# ── 티커 매핑 (기본: config/ticker_map.yaml) ──
# TICKER_MAP_PATH=

# ── 추출 레이어 성능 ──
# 리포트 본문을 이 글자 수로 잘라 LLM 프롬프트 토큰/추론시간을 제한
EXTRACT_PROMPT_MAX_CHARS=12000

# ── Freshness: 시장 데이터 (전부 무료 티어) ──
# Stooq(1순위)는 키 불필요. 아래는 fallback 전용, 없으면 skip.
ALPHAVANTAGE_API_KEY=
FINNHUB_API_KEY=
# FRED 매크로(금리/CPI). 키 없으면 매크로 섹션 생략
FRED_API_KEY=

# ── Freshness: 소셜 (선택) ──
# Reddit(PRAW) — 세 값 모두 있어야 활성화. pip install praw 필요
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=
# Google Trends(pytrends)는 키 불필요. pip install pytrends 필요(없으면 자동 skip)

# ── Freshness: 캐시 ──
CACHE_DIR=./.cache
FRESHNESS_TTL_HOURS=6
